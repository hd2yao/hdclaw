# ------------------------------
# OpenClaw Dashboard environment
# ------------------------------
ENVIRONMENT=dev
COMPOSE_PROJECT_NAME=openclaw-dashboard
NODE_ENV=production

# Ports
NGINX_HTTP_PORT=8088
FRONTEND_PORT=8080
BACKEND_PORT=3000
PORT=3000

# Security
DASHBOARD_API_TOKEN=change-me-super-long-random-token
CORS_ORIGIN=http://localhost:8088
VITE_DASHBOARD_HTTP_URL=/api
VITE_DASHBOARD_WS_URL=/ws

# Database
DASHBOARD_DB_PATH=/app/data/dashboard.db
SQLITE_BUSY_TIMEOUT_MS=5000

# Polling / node sync
NODE_POLL_INTERVAL_MS=5000
NODE_HEARTBEAT_TIMEOUT_MS=15000
NODE_RECONNECT_MIN_MS=1000
NODE_RECONNECT_MAX_MS=30000

# Logging
LOG_LEVEL=info
LOG_AGGREGATION_ENABLED=false
LOKI_URL=http://loki:3100/loki/api/v1/push

# Backups
BACKUP_INTERVAL_SEC=86400
BACKUP_RETENTION_DAYS=7

# Optional runtime metadata
TZ=UTC
