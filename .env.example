# Copy to .env.local and fill real values (do NOT commit)
CLAWRA_IMAGE_PROVIDER=fal
CLAWRA_IMAGE_MODEL=gpt-image-1
OPENAI_API_KEY=
FAL_KEY=
RUNWARE_API_KEY=
# Optional lock-face controls (Fal provider)
CLAWRA_REFERENCE_IMAGE=https://cdn.jsdelivr.net/gh/SumeLabs/clawra@main/assets/clawra.png
CLAWRA_SELFIE_MODE=auto
CLAWRA_USE_REFERENCE_IMAGE=true

# OpenClaw LLM switch (openai-codex or local)
OPENCLAW_LLM_MODE=openai-codex
OPENCLAW_OPENAI_MODEL=openai-codex/gpt-5.3-codex

# Local model (used when OPENCLAW_LLM_MODE=local)
OPENCLAW_LOCAL_PROVIDER=local
OPENCLAW_LOCAL_MODEL_ID=my-local-model
OPENCLAW_LOCAL_MODEL_NAME=Local-Model
OPENCLAW_LOCAL_BASE_URL=http://127.0.0.1:1234/v1
# openai-responses (preferred) or openai-completions (for chat/completions style servers)
OPENCLAW_LOCAL_API=openai-responses
OPENCLAW_LOCAL_API_KEY=local-noauth
OPENCLAW_LOCAL_CONTEXT_WINDOW=128000
OPENCLAW_LOCAL_MAX_TOKENS=8192
OPENCLAW_LOCAL_REASONING=false
# Optional: raw JSON object forwarded to the local model request params
# Example (Qwen/SGLang disable thinking):
# OPENCLAW_LOCAL_MODEL_PARAMS_JSON='{"chat_template_kwargs":{"enable_thinking":false}}'
OPENCLAW_LOCAL_MODEL_PARAMS_JSON=
# Optional: adapt SGLang textual <tool_call> output to OpenAI tool_calls
# off | sglang
OPENCLAW_LOCAL_TOOLCALL_ADAPTER=off
OPENCLAW_LOCAL_TOOLCALL_ADAPTER_BASE_URL=http://127.0.0.1:31001/v1
# Adapter stream behavior (used by scripts/sglang-toolcall-adapter.mjs)
SGLANG_ADAPTER_STREAM_MODE=proxy
SGLANG_ADAPTER_STREAM_FALLBACK=on

# Optional: control pre-compaction memory flush turn (true | false)
# When OPENCLAW_LOCAL_TOOLCALL_ADAPTER=sglang and this is unset, sync defaults to false.
OPENCLAW_MEMORY_FLUSH_ENABLED=true
# Default thinking level for agent turns (off|minimal|low|medium|high|xhigh)
OPENCLAW_THINKING_DEFAULT=off
# Telegram draft stream mode override: keep|off|partial|block
# keep = do not change existing channels.telegram.streamMode
OPENCLAW_TELEGRAM_STREAM_MODE=off

# Web search tool mode
# auto: use brave only when API key exists, otherwise disable web_search
# off: always disable web_search (recommended for local model without Brave key)
# brave: force-enable web_search (requires key)
OPENCLAW_WEB_SEARCH_MODE=auto
# Optional when OPENCLAW_WEB_SEARCH_MODE=brave
OPENCLAW_WEB_SEARCH_API_KEY=

# Tavily skill (optional, required only when using tavily-search)
TAVILY_API_KEY=

# Daily AI news automation
AI_NEWS_OBSIDIAN_DIR=/Users/dysania/program/documents/obsidian_vault/news/daily
AI_NEWS_TELEGRAM_TARGET=TODO_SET_CHAT_ID
AI_NEWS_AGENT_ID=main
AI_NEWS_TZ=Asia/Shanghai
AI_NEWS_CRON="30 8 * * *"
AI_NEWS_LOOKBACK_HOURS=24
AI_NEWS_FALLBACK_HOURS=48
AI_NEWS_TOP_N=10
AI_NEWS_PICK_N=3
