# Copy to .env.local and fill real values (do NOT commit)
CLAWRA_IMAGE_PROVIDER=fal
CLAWRA_IMAGE_MODEL=gpt-image-1
OPENAI_API_KEY=
FAL_KEY=
RUNWARE_API_KEY=
# Optional lock-face controls (Fal provider)
CLAWRA_REFERENCE_IMAGE=https://cdn.jsdelivr.net/gh/SumeLabs/clawra@main/assets/clawra.png
CLAWRA_SELFIE_MODE=auto
CLAWRA_USE_REFERENCE_IMAGE=true

# Daily AI news automation
AI_NEWS_OBSIDIAN_DIR=/Users/dysania/program/documents/obsidian_vault/news/daily
AI_NEWS_TELEGRAM_TARGET=TODO_SET_CHAT_ID
AI_NEWS_AGENT_ID=main
AI_NEWS_TZ=Asia/Shanghai
AI_NEWS_CRON="30 8 * * *"
AI_NEWS_LOOKBACK_HOURS=24
AI_NEWS_FALLBACK_HOURS=48
AI_NEWS_TOP_N=10
AI_NEWS_PICK_N=3
